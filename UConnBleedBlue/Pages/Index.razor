@page "/"

@inject NavigationManager Nav
@inject UConnBleedBlue.Models.DonationsService Donations

@* Notes:
   1rem = root font size (typically 16px). So:
   2.5rem ≈ 40px
   3.125rem ≈ 50px *@


<ErrorBoundary>

    <ChildContent>

        <PageTitle>Football Alumni News</PageTitle>

        <div class="top-layout">
            <aside class="donate-card">
                <div class="donate-title">Please Donate</div>
                <div class="donate-sub">Current 2026 Donations</div>
                <div class="donate-amount">@($"{Donations.TotalDonations:C0}")</div>

                @if (!string.IsNullOrWhiteSpace(Donations.Error))
                {
                    <div class="donate-error">@Donations.Error</div>
                }

                @if (!string.IsNullOrWhiteSpace(_loadError))
                {
                    <div class="donate-error">@_loadError</div>
                }
                <div class="donate-buttons">
                    <button class="donate-btn" @onclick="GotoDonation" type="button">Donate</button>
                    <button class="donate-btn" @onclick="GotoDonation" type="button">View List</button>
                </div>
            </aside>

            <section class="top-content top-mini">
                <NavLink class="event-banner-link" href="detailsFourthAnnual">
                    <div class="event-banner" aria-label="4th Annual Bleed Blue With Andy - October 3rd 2026 vs. Syracuse">
                        <div class="event-banner-line event-banner-main">4th Annual</div>
                        <div class="event-banner-line event-banner-title">'Bleed Blue With Andy'</div>
                        <div class="event-banner-line event-banner-date">
                            October 3rd 2026 <span class="event-banner-vs">vs.</span> <span class="event-banner-syracuse">Syracuse</span>
                        </div>
                    </div>
                </NavLink>

                <div class="banner-click-note">
                    Click banner for Syracuse game details
                </div>

 
            </section>

        </div>


        @if (imageSource1 is not null)
        {
            <div class="hero-grid">
                <!-- Left image -->
                <img src="@imageSource1" asp-append-version="true" class="hero-img1" />

                <!-- Right column: image only -->
                <div class="right-col">
                    @if (!string.IsNullOrWhiteSpace(imageSource2))
                    {
                        <img src="@imageSource2" asp-append-version="true" class="hero-img2" />
                    }
                </div>
            </div>

            @if (!string.IsNullOrWhiteSpace(rightBlurb))
            {
                <p class="right-blurb">@rightBlurb</p>
            }
        }
    </ChildContent>

    <ErrorContent>
        <p style="color:red;">Oops, something went wrong on this page.</p>
    </ErrorContent>
</ErrorBoundary>

<style>

    .banner-click-note {
        text-align: center;
        color: #0033cc;
        font-size: 1.25rem;
        font-weight: bold;
        margin-top: -0.25rem;
        margin-bottom: 0.75rem;
    }

    .event-banner-link {
        display: block;
        text-decoration: none;
        margin: 0.5rem auto 1rem auto;
        width: min(96%, 1180px);
    }

    .event-banner {
        position: relative;
        margin: 0 auto;
        padding: 1.1rem 1.4rem;
        border: 5px solid #0033cc;
        border-radius: 8px;
        background: linear-gradient(180deg, #ffffff 0%, #f4f8ff 100%);
        box-shadow: 0 0 14px rgba(0, 51, 204, 0.55), 0 4px 10px rgba(0, 0, 0, 0.22);
        text-align: center;
        transition: transform 0.18s ease-in-out, box-shadow 0.18s ease-in-out;
    }

    .event-banner::before,
    .event-banner::after {
        content: "";
        position: absolute;
        top: 50%;
        width: 42px;
        height: 5px;
        background: #0033cc;
        border-radius: 999px;
        box-shadow: 0 -18px 0 #0033cc, 0 18px 0 #0033cc;
    }

    .event-banner::before {
        left: -58px;
        transform: translateY(-50%) rotate(0deg);
    }

    .event-banner::after {
        right: -58px;
        transform: translateY(-50%) rotate(0deg);
    }

    .event-banner-link:hover .event-banner,
    .event-banner-link:focus .event-banner {
        transform: scale(1.015);
        box-shadow: 0 0 22px rgba(0, 51, 204, 0.8), 0 5px 14px rgba(0, 0, 0, 0.28);
    }

    .event-banner-line {
        font-family: Impact, Haettenschweiler, 'Arial Narrow Bold', sans-serif;
        font-weight: 900;
        text-transform: uppercase;
        line-height: 0.98;
        letter-spacing: 0.04em;
        color: #001e5a;
        text-shadow: 2px 3px 4px rgba(0, 0, 0, 0.22);
    }

    .event-banner-main {
        font-size: clamp(2.5rem, 6vw, 5.2rem);
    }

    .event-banner-title {
        font-size: clamp(2.2rem, 5.4vw, 4.7rem);
    }

    .event-banner-date {
        font-size: clamp(1.9rem, 4.8vw, 4rem);
        margin-top: 0.25rem;
    }

    .event-banner-vs {
        color: #001e5a;
    }

    .event-banner-syracuse {
        color: #f76900;
        -webkit-text-stroke: 2px #0033cc;
        paint-order: stroke fill;
        text-shadow: 2px 2px 0 #0033cc, -1px -1px 0 #0033cc, 3px 4px 5px rgba(0, 0, 0, 0.25);
    }
    .top-header {
        font-size: clamp(1.4rem, 5.5vw, 2.4rem);
        font-weight: 700;
        color: mediumblue;
        text-align: center;
        text-shadow: 0.5px 0.5px 0.5px rgba(0, 0, 255, 0.15); /* very subtle blue glow */
        padding: 0.25rem;
        white-space: normal;
    }

    /* Smaller, tighter headers for the very top area */
    .top-mini h2 {
        font-size: clamp(1.05rem, 3.8vw, 1.75rem);
        padding: 0.15rem;
    }

    /* Center column expands and keeps content centered */
    .top-content {
        flex: 1 1 auto; /* take remaining width */
        min-width: 280px; /* prevents squish */
        display: flex;
        flex-direction: column;
        justify-content: center; /* vertical balance vs the side cards */
        gap: 0.2rem; /* NOTE: this was the final value previously */
    }

        .top-content .top-header,
        .top-content .row-header {
            text-align: center; /* keep headers centered */
        }

    h1 {
        display: table;
        margin: 0.625rem auto; /* 10px */
        padding: 0.3125rem; /* 5px */
        font-size: clamp(1.5rem, 6vw, 3.125rem); /* ~24px to 50px */
        color: blue;
        overflow: hidden;
    }

    h2 {
        display: table;
        margin: 0.625rem auto; /* 10px */
        padding: 0.3125rem; /* 5px */
        font-size: clamp(1.2rem, 5vw, 2.2rem); /* 35px */
        font-weight: bold;
        color: blue;
        overflow: hidden;
    }

    .link-header h2 {
        text-decoration: underline;
        color: #004aad; /* strong UConn blue */
        transition: all .2s ease-in-out;
        cursor: pointer;
    }

    .photo-link {
        color: #004aad; /* strong UConn blue */
        text-decoration: underline;
        transition: all .2s ease-in-out;
        cursor: pointer;
    }

        /* Shared hover look */
        .link-header:hover h2,
        .photo-link:hover {
            color: #d40000; /* bright attention red */
            background-color: #f2f2f2; /* slight highlight */
            border-radius: 6px;
            transform: scale(1.02);
        }

    .row-header {
        font-weight: bold;
        font-size: clamp(1.05rem, 3.8vw, 1.75rem); /* match top-header */
        transition: all 0.2s ease-in-out;
    }

    /* two-up hero layout */
    .hero-grid {
        max-width: 90%;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1.4fr 1fr; /* left wider */
        gap: 0.75rem;
        align-items: start;
    }

    /* images */
    .hero-img1,
    .hero-img2 {
        width: 100%;
        height: auto; /* let the browser pick the height */
        max-height: 60vh; /* never taller than 60% of the viewport height */
        object-fit: cover;
        border: 2px solid #004aad;
        border-radius: 8px;
        display: block;
    }

    /* right column container */
    .right-col {
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
    }

    /* styled blurb under right image */
    .right-blurb {
        margin: 0.4rem auto 0 auto;
        max-width: 90%;
        padding: 0.35rem 1rem;
        background: #004aad;
        border-radius: 6px;
        font-size: clamp(0.85rem, 1.8vw, 1.05rem);
        line-height: 1.2;
        color: #ffde59;
        font-weight: 600;
        text-align: center;
        white-space: nowrap;
        overflow: hidden;
        text-overflow: ellipsis;
        box-shadow: 2px 2px 6px rgba(0,0,0,0.15);
    }

    /* space items left/center/right neatly on desktop */
    .top-layout {
        display: flex;
        align-items: stretch; /* same heights feel balanced */
        justify-content: space-between;
        gap: 1rem;
        margin: 0 1rem 0.75rem 1rem;
    }

    /* Shared palette look for both cards */
    .donate-card,
    .parking-card {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.3rem;
        padding: 0.5rem 1rem;
        width: 220px;
        flex: 0 0 220px;
        border: 2px solid #004aad;
        border-radius: 12px;
        background: linear-gradient(145deg, #f3f7ff, #e7efff);
        box-shadow: 2px 3px 6px rgba(0, 0, 0, 0.08);
        text-align: center;
    }

    .donate-buttons {
        display: flex;
        flex-direction: row;
        gap: 0.5rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 0.3rem;
    }

    /* Titles (both) */
    .donate-title,
    .parking-title {
        font-weight: 900;
        font-size: clamp(1.25rem, 3vw, 1.6rem);
        color: #0057d8;
        text-shadow: 0 0 2px rgba(0, 90, 255, 0.15);
        letter-spacing: 0.5px;
    }

    /* Subheads (both) */
    .donate-sub,
    .parking-sub {
        position: relative;
        font-weight: 700;
        font-size: clamp(1.1rem, 2.8vw, 1.35rem);
        color: #004aad;
        letter-spacing: 0.4px;
        padding-bottom: 0.35rem;
        margin-bottom: 0.35rem;
    }

        .donate-sub::after,
        .parking-sub::after {
            content: "";
            display: block;
            width: 60%;
            height: 2px;
            background: rgba(0, 74, 173, 0.25);
            margin: 0.35rem auto 0 auto;
            border-radius: 1px;
        }

    /* donation amount */
    .donate-amount {
        font-size: clamp(1.4rem, 3.5vw, 1.9rem);
        font-weight: 800;
        color: #005cff;
        letter-spacing: 0.4px;
        margin-top: 0.2rem;
    }

    .donate-error {
        color: #b30000;
        font-size: 0.95rem;
    }

    /* Buttons (both) */
    .donate-btn,
    .parking-btn {
        margin-top: 0;
        background-color: #0057d8;
        color: #fffbf2;
        border: none;
        border-radius: 10px;
        padding: 0.45rem 0.8rem;
        font-size: clamp(0.85rem, 2vw, 1rem);
        font-weight: 700;
        letter-spacing: 0.3px;
        cursor: pointer;
        transition: background-color 0.2s ease-in-out, transform 0.1s ease-in-out, box-shadow 0.2s;
        box-shadow: 2px 3px 6px rgba(0, 0, 0, 0.1);
    }

        .donate-btn:hover, .donate-btn:focus,
        .parking-btn:hover, .parking-btn:focus {
            background-color: #003ea8;
            color: #ffffff;
            transform: translateY(-1px);
            box-shadow: 3px 4px 8px rgba(0, 0, 0, 0.15);
            outline: none;
        }

    /* stack on phones */
    @@media (max-width: 768px) {
        .event-banner::before,
        .event-banner::after {
            display: none;
        }

        .event-banner {
            padding: 0.9rem 0.8rem;
        }

        .event-banner-syracuse {
            -webkit-text-stroke: 1px #0033cc;
        }

        .hero-grid {
            grid-template-columns: 1fr;
        }

        .top-layout {
            flex-direction: column;
            align-items: stretch;
        }

        .donate-card, .parking-card {
            width: 100%;
            flex: 0 0 auto;
        }
    }
</style>


@code {

    private string imageSource1 = $"GroupPhoto2025.webp";
    private string imageSource2 = $"GlassEtching2025.webp";
    private string rightBlurb = "Glass etching created by Skip Gorski (1971) — won by Rich Foye (1973)";

    private string? _loadError;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            await Donations.EnsureLoadedAsync(); // harmless if already loaded
        }
        catch (Exception ex)
        {
            _loadError = $"Error loading donations: {ex.Message}";
        }
    }

    private void GotoTicketForm()
    {
        Nav.NavigateTo("/ticket-request-form");
    }

    private void GotoDonation() => Nav.NavigateTo("/make-donation");

    private void GotoParking() => Nav.NavigateTo("/purchase-parking");
}
