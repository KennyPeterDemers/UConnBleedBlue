@page "/1965WeBeatYale"

<PageTitle>We Beat Yale</PageTitle>

<div class="documents-container">

    <h1 class="documents-title">
        We Beat Yale
    </h1>

    <ul class="documents-list">
        <li>
            <a href="/Data/_1966NutmegYearbook.pdf"
               target="_1966NutmegYearbook"
               rel="noopener noreferrer">
                Nutmeg Yearbook – 1966
            </a>
        </li>

        <li>
            <a href="/Data/_SilverAnniversaryRatPack.pdf"
               target="_SilverAnniversaryRatPack"
               rel="noopener noreferrer">
                Silver Anniversary Rat Pack
            </a>
        </li>

        <li>
            <a href="/Data/_StorrsCentralArticle.pdf"
               target="_StorrsCentralArticle"
               rel="noopener noreferrer">
