@page "/PlayersThatDonated"

@using UConnBleedBlue.Models

@inject NavigationManager NavigationManager;


@if (donationsService == null)
{
    <p><em>Loading...</em></p>
}
else
{
    <table class="table table-striped colorBlue">
        <thead>
            <tr>
                <th></th>
                <th>Name</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var donation in @donationsService.DonationList)
            {
                <tr>
                    <td>@donation.PlayerId</td>
                    <td>@donation.PlayerName</td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    public DonationsService donationsService = new DonationsService();

    string err = "";

    protected override void OnInitialized()
    {
        try
        {
        }
        catch (Exception ex)
        {
            err = ex.Message;
        }
    }

}
