@page "/photoGalleryTeams"

<style>
    .center {
        display: block;
        margin-left: auto;
        margin-right: auto;
        width: 90%;
        height: 90%;
        border: 2px solid blue;
    }
</style>


@if (img1 is not null)
{
    <FluentStack HorizontalGap="10" VerticalGap="10">
        <FluentButton Appearance="Appearance.Accent" OnClick="@Pause">@labelText @sequenceNumber</FluentButton>
        <p style="color:blue;font-size:x-large;align-content:center">
            @year
        </p>
    </FluentStack>


    <div>
        <img class="center" src="@img1">
    </div>
}

@code {
    public string? img1 { get; set; }
    List<string> fileList1 = new List<string>();
    string path1 = $"{Directory.GetCurrentDirectory()}{@"\wwwroot\imagesTeamPhotos"}";
    int index = 0;
    Timer? timer;
    string sequenceNumber = "";
    int max = 1;
    string err = "";
    string labelText = "Click To Pause The Images Changing:  ";
    string year = "1900";

    protected override void OnInitialized()
    {
        try
        {
            LoadImages();

            if (timer != null)
            {
                timer.Dispose();
            }
            timer = new Timer(OnTimerEvent, null, 500, 5000);

        }
        catch (Exception ex)
        {
            err = ex.Message;
        }
    }
    public void LoadImages()
    {
        string[] files;

        try
        {
            files = Directory.GetFiles(path1);
            foreach (var file in files)
            {
                if (int.Parse(Path.GetFileNameWithoutExtension(file)) < 1960)
                {
                    continue;
                }
                fileList1.Add("imagesTeamPhotos/" + Path.GetFileName(file));
            }
            max = fileList1.Count;
            sequenceNumber = String.Format("{0} of {1}", index + 1, fileList1.Count);
            img1 = fileList1[0];
        }
        catch (Exception ex)
        {
            err = ex.Message;
        }
    }
    private void OnTimerEvent(object? state)
    {
        try
        {
            img1 = fileList1[index++];
            year = img1.Split(".")[0].Split("/")[1];
            if (index >= fileList1.Count)
            {
                index = 0;
            }
            sequenceNumber = String.Format("{0} of {1}", index, fileList1.Count);
            InvokeAsync(StateHasChanged);
        }
        catch (Exception ex)
        {
            err = ex.Message;
        }
    }
    private void Pause()
    {
        timer?.Dispose();
        timer = null;
        if (labelText.Contains("Pause"))
        {
            labelText = "Click To Continue The Images Changing:  ";
        }
        else
        {
            timer = new Timer(OnTimerEvent, null, 500, 3000);
            labelText = "Click To Pause The Images Changing:  ";
        }
    }
}
