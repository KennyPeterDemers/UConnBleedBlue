@using UConnBleedBlue.Models

@inject DonationsService DonationsService
@inject PlayersService PlayersService

<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">UConnBleedBlue</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="nav-bullet">›</span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tributeToCoachB">
                <span class="nav-bullet">›</span> Tributes To Coach B
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link yellow-link" href="photoGallery2025">
                <span class="nav-bullet">›</span> 2025 Photo Gallery
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="playersAttending">
                <span class="nav-bullet">›</span> Attendance List  ( @PlayersService.PlayerList.Count(p => p.AttendingTailgate) )
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="menu">
                <span class="nav-bullet">›</span> Tailgate Menu
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tailgate-location">
                <span class="nav-bullet">›</span> Tailgate Location
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <a class="nav-link nav-external" href="https://youtu.be/IxwKho5wkDE?si=tyPSWcZT0gPNufK5taid=68823c8385489b00010acfa9&utm_campaign=trueanthem&utm_medium=social&utm_source=twitter" target="_blank" rel="noopener noreferrer">
                <span class="nav-bullet">›</span> Tailgate Video
            </a>
        </div>
        <div class="nav-item px-3">
            <a class="nav-link nav-external" href="https://www.nhregister.com/sports/uconn/article/andy-baylock-uconn-baseball-football-20779937.php" target="_blank" rel="noopener noreferrer">
                <span class="nav-bullet">›</span> Andy Baylock Article
            </a>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="1965webeatyale">
                <span class="nav-bullet">›</span> We Beat Yale - 1965
            </NavLink>
        </div>
        <div class="nav-item px-3" @onclick:stopPropagation>
            <button class="nav-link btn btn-link w-100 text-start d-flex align-items-center"
                    type="button"
                    @onclick="TogglePhotos"
                    @onclick:stopPropagation>
                <span class="nav-bullet">›</span>
                Photo Gallery
                <span class="ms-auto oi oi-chevron-bottom @(photosOpen ? "rotate-180" : "")"
                      aria-hidden="true"></span>
            </button>

            @* NOTE: no 'collapse' class here *@
            <div class="submenu" style="@(photosOpen ? "display:block;" : "display:none;")" @onclick:stopPropagation>
                <NavLink class="nav-link nav-sublink ms-4" href="photoGallery2025">Photo Gallery 2025</NavLink>
                <NavLink class="nav-link nav-sublink ms-4" href="photoGallery1">Photo Gallery 1</NavLink>
                <NavLink class="nav-link nav-sublink ms-4" href="photoGallery2">Photo Gallery 2</NavLink>
                <NavLink class="nav-link nav-sublink ms-4" href="photoGallery3">Photo Gallery 3</NavLink>
                <NavLink class="nav-link nav-sublink ms-4" href="photoGallery4">Photo Gallery 4</NavLink>
            </div>
        </div>
        <div class="nav-item px-3">
            <button class="nav-link btn btn-link w-100 text-start d-flex align-items-center"
                    type="button"
                    @onclick="ToggleTeams"
                    @onclick:stopPropagation>
                <span class="nav-bullet">›</span>
                Team Photos
                <span class="ms-auto oi oi-chevron-bottom @(teamsOpen ? "rotate-180" : "")" aria-hidden="true"></span>
            </button>

            @* We control visibility ourselves (no Bootstrap 'collapse' class) *@
            <div class="submenu" style="@(teamsOpen ? "display:block;" : "display:none;")">
                <NavLink class="nav-link nav-sublink ms-4" href="photoGalleryTeams60-89">
                    Teams 1960–1989
                </NavLink>
                <NavLink class="nav-link nav-sublink ms-4" href="photoGalleryTeams90-24">
                    Teams 1990–2024
                </NavLink>
            </div>
        </div>
    </nav>

    <!-- Sponsor (plain text) -->
    <div class="sponsor-section" @onclick:stopPropagation>
        <h3 class="sponsor-title">Tailgate Sponsors</h3>
        <ul class="sponsor-list">
            <li>Hall's Market'</li>
            <li>331 Park Rd.</li>
            <li>West Hartford CT</li>
            <li>860 232-1075</li>
        </ul>
        <div class="sponsor-logo">
            <img src="imagesMenu/HallsMarket.webp" alt="Strano Bakery" />
        </div>
    </div>
</div>


<style>

    .nav-bullet {
        font-size: 1.3rem;
        font-weight: 700;
        color: #ffcc00;
        margin-right: 0.3rem;
        line-height: 1;
    }

    /* Bright white, larger font for all nav items */
    .nav-scrollable .nav-link,
    .nav-scrollable .btn-link {
        color: #ffffff !important;
        font-size: 1.05rem;
        font-weight: 500;
    }

    .nav-scrollable .nav-link:hover,
    .nav-scrollable .btn-link:hover {
        color: #ffcc00 !important;
        background-color: rgba(255, 255, 255, 0.08);
    }

    .nav-scrollable .nav-link.active {
        color: #ffcc00 !important;
        font-weight: 700;
        background-color: rgba(255, 255, 255, 0.12);
    }

    .nav-external {
        color: #ffffff;
        white-space: nowrap;
    }

    .nav-external:hover {
        color: #ffcc00;
        text-decoration: none;
    }

    .submenu .nav-sublink {
        font-size: 0.95rem;
        padding-left: 0.25rem;
    }

    .rotate-180 {
        transform: rotate(180deg);
        transition: transform 180ms ease;
    }

    /* Make active sub-links stand out a bit */
    .nav-sublink.active {
        font-weight: 600;
        text-decoration: underline;
    }

    .sponsor-section {
        margin-top: 0.75rem;
        padding: 0.5rem 0.75rem 0.75rem;
        border-top: 1px solid rgba(255,255,255,0.25);
        color: #fff; /* ensure visible on blue */
        font-size: 0.95rem;
        line-height: 1.4;
    }

    .sponsor-title {
        margin: 0 0 0.4rem 0;
        font-size: 1.25rem;
        font-weight: 600;
        color: #ff8844;
    }

    .sponsor-list {
        list-style: none;
        margin: 0;
        padding: 0;
        font-size: 1.5rem;
        font-weight: bold;
        color: #ffcc00;
    }

    .sponsor-list li {
        margin-bottom: 0.25rem;
    }
</style>
@code {
    //private string playersThatDonatedPageLabel = "";

    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private string err = "";

    //PlayersService playersService = new PlayersService();

    //DonationsService donationsService = new DonationsService();

    private bool photosOpen = false;

    private bool teamsOpen = false;

    protected override void OnInitialized()
    {
        try
        {
            //playersThatDonatedPageLabel = $"Current Donors  {DonationsService.TotalDonations}";
        }
        catch (Exception ex)
        {
            err = ex.Message;
        }
    }
    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
    private void TogglePhotos()
    {
        photosOpen = !photosOpen;
    }
    private void ToggleTeams()
    {
        teamsOpen = !teamsOpen;
    }
}
