@using UConnBleedBlue.Models


<div class="top-row ps-3 navbar navbar-dark">
    <div class="container-fluid">
        <a class="navbar-brand" href="">UConnBleedBlue</a>
        <button title="Navigation menu" class="navbar-toggler" @onclick="ToggleNavMenu">
            <span class="navbar-toggler-icon"></span>
        </button>
    </div>
</div>

<div class="@NavMenuCssClass nav-scrollable" @onclick="ToggleNavMenu">
    <nav class="flex-column">
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="" Match="NavLinkMatch.All">
                <span class="oi oi-home" aria-hidden="true"></span> Home
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="attendenceForm">
                <span class="oi oi-list-rich" aria-hidden="true"></span> Attendence Form
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="obtainTicketsAndParking">
                <span class="oi oi-list-rich" aria-hidden="true"></span> Tickets & Parking
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="playersAttending">
                <span class="oi oi-list-rich" aria-hidden="true"></span> @playersAttendingPageLabel
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Donate">
                <span class="oi oi-list-rich" aria-hidden="true"></span> @donatePageLabel
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="Costs">
                <span class="oi oi-list-rich" aria-hidden="true"></span> @costsPageLabel
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="PlayersThatDonated">
                <span class="oi oi-list-rich" aria-hidden="true"></span> @playersThatDonatedPageLabel
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="photoGallery1">
                <span class="oi oi-list-rich" aria-hidden="true"></span> Photo Gallery
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="photoGalleryTeams">
                <span class="oi oi-list-rich" aria-hidden="true"></span> Team Photo Gallery
            </NavLink>
        </div>
        <div class="nav-item px-3">
            <NavLink class="nav-link" href="tributeToCoachB">
                <span class="oi oi-list-rich" aria-hidden="true"></span> Tribute To Coach B
            </NavLink>
        </div>
        @*         <div class="nav-item px-3">
            <NavLink class="nav-link" href="videoGallery">
                <span class="oi oi-list-rich" aria-hidden="true"></span> Video Gallery
            </NavLink>
        </div>
 *@
        @*        <div class="nav-item px-3">
            <NavLink class="nav-link" href="fetchdata">
                <span class="oi oi-list-rich" aria-hidden="true"></span> Fetch data
            </NavLink>
        </div> *@
    </nav>
</div>

@code {
    private string playersAttendingPageLabel = "";

    private string playersThatDonatedPageLabel = "";

    private string donatePageLabel = "Donate";

    private string costsPageLabel = "";

    private bool collapseNavMenu = true;

    private string? NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private string err = "";

    DonationsService donationsService = new DonationsService();

    PlayersService playersService = new PlayersService();

    CostsService costsService = new CostsService();

    protected override void OnInitialized()
    {
        try
        {
            costsPageLabel = string.Format("Tailgate Costs  ${0}", costsService.TotalCosts);

            //donatePageLabel = "Donate: " + donationsService.TotalDonations.ToString("C");

            playersAttendingPageLabel = $"Players Attending  {playersService.PlayerList.Count}";

            playersThatDonatedPageLabel = $"Current Donors  {donationsService.NumberOfPeopleDonating}";
        }
        catch (Exception ex)
        {
            err = ex.Message;
        }
    }
    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}
